{
  "dataset": {
    "voc_root": "VOCdevkit",
    "class_names": [
      "_background_",
      "building",
      "sky",
      "tree",
      "way"
    ],
    "class_colors": [
      [
        0,
        0,
        0
      ],
      [
        128,
