# ---- 环境 ----
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.idea/

# ---- 模型权重 ----
# *.pth / *.onnx 由 Git LFS 跟踪（见 .gitattributes），不在这里忽略。
# 注意：本仓库没有远程，LFS 对象存在 .git/lfs/objects，仍在同一块磁盘上。
# 它防的是误删/误覆盖，不是磁盘故障 —— 异地备份仍然必须做。
*.pt

# ---- 外部数据集（README 明确要求不提交）----
data_external/
VOCdevkit_uavid/
VOCdevkit_ruralscapes/

# ---- 预测输入/输出（体积大且可再生）----
img/
img_out/
img_out_selftest/
miou_out_selftest/

# ---- 运行时产物 ----
logs*/loss_*/
logs*/train_config.json
# 评估页/QML 后端每次运行都会重写它，内容含绝对路径，不该进版本库
miou_out/eval_config.json
miou_out/detection-results/
.temp_miou_out/
*.log
stop.flag
studio_error.log
workstation_error.log

# ---- 数据集掩码备份（148 张原始 RGB 标签，占地但需保留在本地）----
VOCdevkit/_mask_backup_rgb/
